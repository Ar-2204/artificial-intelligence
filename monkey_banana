from collections import deque

def solve():
    start = ('door', 'onfloor', 'window', 'hasnot')
    visited = set()
    queue = deque([(start, [])])

    locations = ['door', 'window', 'middle']

    while queue:
        state, path = queue.popleft()

        if state in visited:
            continue
        visited.add(state)

        m_pos, m_state, box_pos, banana = state


        if banana == 'has':
            print("Solution Found:\n")
            for step in path:
                print(step)
            return


        if m_state == 'onfloor':
            for new_pos in locations:
                if new_pos != m_pos:
                    new_state = (new_pos, 'onfloor', box_pos, banana)
                    queue.append((new_state, path + [f"Monkey goes from {m_pos} to {new_pos}"]))


        if m_state == 'onfloor' and m_pos == box_pos:
            for new_pos in locations:
                if new_pos != box_pos:
                    new_state = (new_pos, 'onfloor', new_pos, banana)
                    queue.append((new_state, path + [f"Monkey pushes box from {box_pos} to {new_pos}"]))

        if m_state == 'onfloor' and m_pos == box_pos:
            new_state = (m_pos, 'onbox', box_pos, banana)
            queue.append((new_state, path + ["Monkey climbs onto the box"]))


        if m_state == 'onbox':
            new_state = (m_pos, 'onfloor', box_pos, banana)
            queue.append((new_state, path + ["Monkey climbs down from the box"]))


        if m_state == 'onbox' and m_pos == 'middle' and banana == 'hasnot':
            new_state = (m_pos, 'onbox', box_pos, 'has')
            queue.append((new_state, path + ["Monkey grabs the banana"]))

    print("No solution found.")

if __name__ == "__main__":
    solve()
